<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/primary_dark"
    android:layout_height="match_parent"
    tools:context=".presentation.fragment.WelcomeFragment">
    <ImageView
        android:layout_width="match_parent"
        android:layout_gravity="right"
        android:layout_marginTop="120dp"
        android:adjustViewBounds="true"
        android:scaleType="centerCrop"
        android:layout_height="match_parent"
        android:src="@drawable/logo"
        />
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="40dp"
        android:paddingLeft="20dp"
        >
        <LinearLayout
            android:layout_weight="1"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:orientation="horizontal"
            >
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppinsbold"
                android:textSize="64sp"
                android:textColor="@color/white"
                android:text="Crypt"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppinsbold"
                android:textSize="64sp"
                android:textColor="@color/primary_dark_second"
                android:text="X"
                />
        </LinearLayout>

        <ImageView
            android:layout_weight="2.6"
            android:layout_width="wrap_content"
            android:layout_gravity="right"
            android:layout_marginTop="20dp"
            android:layout_marginLeft="150dp"
            android:layout_height="0dp"
            />
        <TextView
            android:layout_weight="1"
            android:layout_width="300dp"
            android:layout_height="0dp"
            android:text="Jump start your crypto portfolio"
            android:fontFamily="@font/poppinssemibold"
            android:textColor="@color/white"
            android:textSize="32sp"
            />
        <TextView
            android:layout_weight="0.5"
            android:layout_width="230dp"
            android:layout_height="0dp"
            android:text="Take your investment portfolio to next level"
            android:fontFamily="@font/poppinsmedium"
            android:textColor="@color/white"
            android:textSize="14sp"
            />
        <androidx.cardview.widget.CardView
            android:layout_weight="0.5"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:cardCornerRadius="16dp"
            android:layout_marginHorizontal="20dp"
            android:backgroundTint="@color/primary_dark_second"
            >
            <TextView
                android:layout_marginVertical="12dp"
                android:layout_width="match_parent"
                android:gravity="center"
                android:layout_height="match_parent"
                android:text="Get Started"
                android:fontFamily="@font/poppinsmedium"
                android:textColor="@color/white"
                android:textSize="14sp"
                />

        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_weight="0.3"
            android:layout_width="wrap_content"
            android:layout_height="0dp"/>
    </LinearLayout>


</RelativeLayout>