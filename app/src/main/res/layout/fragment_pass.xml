<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/primary_dark"
    android:orientation="vertical"
    tools:context=".presentation.fragment.PasswordFragment"
    tools:ignore="MissingDefaultResource">
    <RelativeLayout
        android:layout_weight="1"
        android:layout_marginTop="20dp"
        android:layout_marginLeft="15dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        >

        <ImageView
            android:id="@+id/back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:src="@drawable/ic_bi_arrow_left_short" />
    </RelativeLayout>

    <LinearLayout
        android:layout_weight="1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        >
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="25sp"
            android:layout_gravity="center"
            android:fontFamily="@font/poppinsmedium"
            android:textColor="@color/white"
            android:text="Enter Pin"
            />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:layout_gravity="center"
            android:fontFamily="@font/poppinsmedium"
            android:textColor="@color/opacity_white"
            android:text="Enter Your Pin Code"
            />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_gravity="center"
        android:layout_weight="0.5"
        android:orientation="horizontal"
        >
            <LinearLayout
                android:id="@+id/first_check"
                android:layout_width="10dp"
                android:orientation="horizontal"
                android:layout_height="10dp"
                android:background="@drawable/check_password"/>
            <LinearLayout
                android:id="@+id/second_check"
                android:layout_marginLeft="5dp"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/check_password"
                android:orientation="horizontal" />
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/third_check"
                android:layout_marginLeft="5dp"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/check_password"/>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/fourth_check"
                android:layout_marginLeft="5dp"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/check_password"/>

    </LinearLayout>

    <LinearLayout
        android:layout_marginHorizontal="40dp"
        android:layout_weight="5"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="horizontal"
        >


        <LinearLayout

            android:layout_weight="2"
            android:layout_width="0dp"
            android:gravity="center"
            android:layout_height="match_parent"
            android:orientation="vertical"
            >
            <TextView
                android:layout_marginTop="20dp"
                android:id="@+id/one"
                android:layout_weight="3"
                android:layout_width="70dp"
                android:layout_height="0dp"
                android:background="@drawable/num_button"
                android:textSize="25sp"
                android:gravity="center"
                android:fontFamily="@font/poppinsmedium"
                android:textColor="@color/white"
                android:text="1"
                android:paddingHorizontal="28dp"
                tools:ignore="NestedWeights" />

            <LinearLayout
                android:layout_weight="1"
                android:layout_width="wrap_content"
                android:layout_height="0dp"/>

            <TextView
                android:id="@+id/four"
                android:layout_weight="3"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:background="@drawable/num_button"
                android:textSize="25sp"
                android:gravity="center"
                android:fontFamily="@font/poppinsmedium"
                android:textColor="@color/white"
                android:text="4"
                android:paddingHorizontal="28dp"
                tools:ignore="NestedWeights" />
            <LinearLayout
                android:layout_weight="1"
                android:layout_width="wrap_content"
                android:layout_height="0dp"/>
            <TextView
                android:id="@+id/seven"
                android:layout_weight="3"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:background="@drawable/num_button"
                android:textSize="25sp"
                android:gravity="center"
                android:fontFamily="@font/poppinsmedium"
                android:textColor="@color/white"
                android:text="7"
                android:paddingHorizontal="28dp"
                tools:ignore="NestedWeights" />
            <LinearLayout
                android:layout_weight="1"
                android:layout_width="wrap_content"
                android:layout_height="0dp"/>
            <TextView
                android:id="@+id/ziro"
                android:layout_weight="3"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:background="@drawable/num_button"
                android:textSize="25sp"
                android:gravity="center"
                android:fontFamily="@font/poppinsmedium"
                android:textColor="@color/white"
                android:text="0"
                android:paddingHorizontal="28dp"
                tools:ignore="NestedWeights" />
        </LinearLayout>

        <LinearLayout
            android:layout_weight="2"
            android:layout_width="0dp"
            android:gravity="center"
            android:layout_height="match_parent"
            android:orientation="vertical"
            >
            <TextView
                android:layout_marginTop="20dp"
                android:id="@+id/two"
                android:layout_weight="3"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:background="@drawable/num_button"
                android:textSize="25sp"
                android:gravity="center"
                android:fontFamily="@font/poppinsmedium"
                android:textColor="@color/white"
                android:text="2"
                android:paddingHorizontal="28dp"
                tools:ignore="NestedWeights" />

            <LinearLayout
                android:layout_weight="1"
                android:layout_width="wrap_content"
                android:layout_height="0dp"/>

            <TextView
                android:id="@+id/five"
                android:layout_weight="3"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:background="@drawable/num_button"
                android:textSize="25sp"
                android:gravity="center"
                android:fontFamily="@font/poppinsmedium"
                android:textColor="@color/white"
                android:text="5"
                android:paddingHorizontal="28dp"
                tools:ignore="NestedWeights" />
            <LinearLayout
                android:layout_weight="1"
                android:layout_width="wrap_content"
                android:layout_height="0dp"/>
            <TextView
                android:id="@+id/eight"
                android:layout_weight="3"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:background="@drawable/num_button"
                android:textSize="25sp"
                android:gravity="center"
                android:fontFamily="@font/poppinsmedium"
                android:textColor="@color/white"
                android:text="8"
                android:paddingHorizontal="28dp"
                tools:ignore="NestedWeights" />
            <LinearLayout
                android:layout_weight="1"
                android:layout_width="wrap_content"
                android:layout_height="0dp"/>
            <TextView
                android:id="@+id/complete"
                android:layout_weight="3"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:background="@drawable/num_button"
                android:textSize="25sp"
                android:gravity="center"
                android:fontFamily="@font/poppinsmedium"
                android:textColor="@color/white"
                android:text="✔"
                android:paddingHorizontal="28dp"
                tools:ignore="NestedWeights" />
        </LinearLayout>

        <LinearLayout
            android:layout_weight="2"
            android:layout_width="0dp"
            android:gravity="center"
            android:layout_height="match_parent"
            android:orientation="vertical"
            >
            <TextView
                android:layout_marginTop="20dp"
                android:id="@+id/three"
                android:layout_weight="3"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:background="@drawable/num_button"
                android:textSize="25sp"
                android:gravity="center"
                android:fontFamily="@font/poppinsmedium"
                android:textColor="@color/white"
                android:text="3"
                android:paddingHorizontal="28dp"
                tools:ignore="NestedWeights" />

            <LinearLayout
                android:layout_weight="1"
                android:layout_width="wrap_content"
                android:layout_height="0dp"/>

            <TextView
                android:id="@+id/six"
                android:layout_weight="3"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:background="@drawable/num_button"
                android:textSize="25sp"
                android:gravity="center"
                android:fontFamily="@font/poppinsmedium"
                android:textColor="@color/white"
                android:text="6"
                android:paddingHorizontal="28dp"
                tools:ignore="NestedWeights" />
            <LinearLayout
                android:layout_weight="1"
                android:layout_width="wrap_content"
                android:layout_height="0dp"/>
            <TextView
                android:id="@+id/nine"
                android:layout_weight="3"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:background="@drawable/num_button"
                android:textSize="25sp"
                android:gravity="center"
                android:fontFamily="@font/poppinsmedium"
                android:textColor="@color/white"
                android:text="9"
                android:paddingHorizontal="28dp"
                tools:ignore="NestedWeights" />
            <LinearLayout
                android:layout_weight="1"
                android:layout_width="wrap_content"
                android:layout_height="0dp"/>
            <TextView
                android:id="@+id/delete"
                android:layout_weight="3"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:background="@drawable/num_button"
                android:textSize="25sp"
                android:gravity="center"
                android:fontFamily="@font/poppinsmedium"
                android:textColor="@color/white"
                android:text="-"
                android:paddingHorizontal="28dp"
                tools:ignore="NestedWeights" />
        </LinearLayout>

    </LinearLayout>

    <TextView
        android:layout_weight="2"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:text="Enter your pin code"
        android:fontFamily="@font/poppinsmedium"
        android:textColor="#66FFFFFF"
        android:gravity="center"
        android:layout_gravity="center"
        android:textSize="15sp"/>


</LinearLayout>