<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/primary_dark"
    android:orientation="vertical"
    tools:context=".presentation.fragment.PasswordFragment"
    tools:ignore="MissingDefaultResource">
    <RelativeLayout
        android:layout_weight="1"
        android:layout_marginTop="20dp"
        android:layout_marginLeft="15dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        >

        <ImageView
            android:id="@+id/back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:src="@drawable/ic_bi_arrow_left_short" />
    </RelativeLayout>

    <LinearLayout
        android:layout_weight="1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        >
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="25sp"
            android:layout_gravity="center"
            android:fontFamily="@font/poppinsmedium"
            android:textColor="@color/white"
            android:text="Enter Pin"
            />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:layout_gravity="center"
            android:fontFamily="@font/poppinsmedium"
            android:textColor="@color/opacity_white"
            android:text="Enter Your Pin Code"
            />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_gravity="center"
        android:layout_weight="0.5"
        android:orientation="horizontal"
        >
            <LinearLayout
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/checked_password"/>
            <LinearLayout
                android:layout_marginLeft="5dp"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/check_password"/>
            <LinearLayout
                android:layout_marginLeft="5dp"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/check_password"/>
            <LinearLayout
                android:layout_marginLeft="5dp"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/check_password"/>

    </LinearLayout>

    <LinearLayout
        android:layout_marginHorizontal="40dp"
        android:layout_weight="4.5"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="horizontal"
        >


        <LinearLayout
            android:layout_weight="2"
            android:layout_width="0dp"
            android:gravity="center"
            android:layout_height="match_parent"
            android:orientation="vertical"
            >
            <TextView
                android:layout_weight="3"
                android:layout_width="70dp"
                android:layout_height="0dp"
                android:background="@drawable/num_button"
                android:textSize="25sp"
                android:gravity="center"
                android:fontFamily="@font/poppinsmedium"
                android:textColor="@color/white"
                android:text="1"
                android:paddingHorizontal="28dp"
                tools:ignore="NestedWeights" />

            <LinearLayout
                android:layout_weight="1"
                android:layout_width="wrap_content"
                android:layout_height="0dp"/>

            <TextView
                android:layout_weight="3"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:background="@drawable/num_button"
                android:textSize="25sp"
                android:gravity="center"
                android:fontFamily="@font/poppinsmedium"
                android:textColor="@color/white"
                android:text="4"
                android:paddingHorizontal="28dp"
                tools:ignore="NestedWeights" />
            <LinearLayout
                android:layout_weight="1"
                android:layout_width="wrap_content"
                android:layout_height="0dp"/>
            <TextView
                android:layout_weight="3"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:background="@drawable/num_button"
                android:textSize="25sp"
                android:gravity="center"
                android:fontFamily="@font/poppinsmedium"
                android:textColor="@color/white"
                android:text="7"
                android:paddingHorizontal="28dp"
                tools:ignore="NestedWeights" />
            <LinearLayout
                android:layout_weight="1"
                android:layout_width="wrap_content"
                android:layout_height="0dp"/>
            <TextView
                android:layout_weight="3"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:background="@drawable/num_button"
                android:textSize="25sp"
                android:gravity="center"
                android:fontFamily="@font/poppinsmedium"
                android:textColor="@color/white"
                android:text="0"
                android:paddingHorizontal="28dp"
                tools:ignore="NestedWeights" />
        </LinearLayout>

        <LinearLayout
            android:layout_weight="2"
            android:layout_width="0dp"
            android:gravity="center"
            android:layout_height="match_parent"
            android:orientation="vertical"
            >
            <TextView
                android:layout_weight="3"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:background="@drawable/num_button"
                android:textSize="25sp"
                android:gravity="center"
                android:fontFamily="@font/poppinsmedium"
                android:textColor="@color/white"
                android:text="2"
                android:paddingHorizontal="28dp"
                tools:ignore="NestedWeights" />

            <LinearLayout
                android:layout_weight="1"
                android:layout_width="wrap_content"
                android:layout_height="0dp"/>

            <TextView
                android:layout_weight="3"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:background="@drawable/num_button"
                android:textSize="25sp"
                android:gravity="center"
                android:fontFamily="@font/poppinsmedium"
                android:textColor="@color/white"
                android:text="5"
                android:paddingHorizontal="28dp"
                tools:ignore="NestedWeights" />
            <LinearLayout
                android:layout_weight="1"
                android:layout_width="wrap_content"
                android:layout_height="0dp"/>
            <TextView
                android:layout_weight="3"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:background="@drawable/num_button"
                android:textSize="25sp"
                android:gravity="center"
                android:fontFamily="@font/poppinsmedium"
                android:textColor="@color/white"
                android:text="8"
                android:paddingHorizontal="28dp"
                tools:ignore="NestedWeights" />
            <LinearLayout
                android:layout_weight="1"
                android:layout_width="wrap_content"
                android:layout_height="0dp"/>
            <TextView
                android:layout_weight="3"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:background="@drawable/num_button"
                android:textSize="25sp"
                android:gravity="center"
                android:fontFamily="@font/poppinsmedium"
                android:textColor="@color/white"
                android:text="✔"
                android:paddingHorizontal="28dp"
                tools:ignore="NestedWeights" />
        </LinearLayout>

        <LinearLayout
            android:layout_weight="2"
            android:layout_width="0dp"
            android:gravity="center"
            android:layout_height="match_parent"
            android:orientation="vertical"
            >
            <TextView
                android:layout_weight="3"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:background="@drawable/num_button"
                android:textSize="25sp"
                android:gravity="center"
                android:fontFamily="@font/poppinsmedium"
                android:textColor="@color/white"
                android:text="3"
                android:paddingHorizontal="28dp"
                tools:ignore="NestedWeights" />

            <LinearLayout
                android:layout_weight="1"
                android:layout_width="wrap_content"
                android:layout_height="0dp"/>

            <TextView
                android:layout_weight="3"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:background="@drawable/num_button"
                android:textSize="25sp"
                android:gravity="center"
                android:fontFamily="@font/poppinsmedium"
                android:textColor="@color/white"
                android:text="6"
                android:paddingHorizontal="28dp"
                tools:ignore="NestedWeights" />
            <LinearLayout
                android:layout_weight="1"
                android:layout_width="wrap_content"
                android:layout_height="0dp"/>
            <TextView
                android:layout_weight="3"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:background="@drawable/num_button"
                android:textSize="25sp"
                android:gravity="center"
                android:fontFamily="@font/poppinsmedium"
                android:textColor="@color/white"
                android:text="9"
                android:paddingHorizontal="28dp"
                tools:ignore="NestedWeights" />
            <LinearLayout
                android:layout_weight="1"
                android:layout_width="wrap_content"
                android:layout_height="0dp"/>
            <TextView
                android:layout_weight="3"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:background="@drawable/num_button"
                android:textSize="25sp"
                android:gravity="center"
                android:fontFamily="@font/poppinsmedium"
                android:textColor="@color/white"
                android:text="-"
                android:paddingHorizontal="28dp"
                tools:ignore="NestedWeights" />
        </LinearLayout>

    </LinearLayout>

    <TextView
        android:layout_weight="2"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:text="Enter your pin code"
        android:fontFamily="@font/poppinsmedium"
        android:textColor="#66FFFFFF"
        android:gravity="center"
        android:layout_gravity="center"
        android:textSize="15sp"/>


</LinearLayout>