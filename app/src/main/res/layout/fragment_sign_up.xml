<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/primary_dark"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".presentation.fragment.WelcomeFragment">


    <LinearLayout
        android:layout_weight="2"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:layout_marginTop="50dp"
        android:layout_marginLeft="24dp"
        >
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="34sp"
            android:fontFamily="@font/poppinssemibold"
            android:textColor="@color/white"
            android:text="Sign up"
            />
        <TextView
            android:layout_marginTop="-15dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="34sp"
            android:fontFamily="@font/poppinssemibold"
            android:textColor="@color/white"
            android:text="to continue"
            />
    </LinearLayout>

    <LinearLayout
        android:layout_weight="2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:layout_marginHorizontal="24dp"
        >

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:fontFamily="@font/poppinsmedium"
            android:textColor="@color/opacity_white"
            android:text="Email Adress"
            android:layout_marginLeft="4dp"

            />
        <EditText
            android:layout_marginTop="9dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColorHint="@color/opacity_white"
            android:textColor="@color/white"
            android:hint="Enter email"
            android:inputType="textEmailAddress"
            android:textColorLink="@color/primary_dark_second"
            android:backgroundTint="@color/opacity_white"
            android:paddingBottom="18dp"
            />
    </LinearLayout>
    <LinearLayout
        android:layout_weight="2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:layout_marginHorizontal="24dp"
        >

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:fontFamily="@font/poppinsmedium"
            android:textColor="@color/opacity_white"
            android:text="Passsword"
            android:layout_marginLeft="4dp"

            />
        <EditText
            android:layout_marginTop="9dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:inputType="textPassword"
            android:textColorHint="@color/opacity_white"
            android:textColor="@color/white"
            android:hint="Enter password"
            android:textColorLink="@color/primary_dark_second"
            android:backgroundTint="@color/opacity_white"
            android:paddingBottom="18dp"
            />
    </LinearLayout>
    <LinearLayout
        android:layout_weight="2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:layout_marginHorizontal="24dp"
        >

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:fontFamily="@font/poppinsmedium"
            android:textColor="@color/opacity_white"
            android:text="Confirm password"
            android:layout_marginLeft="4dp"

            />
        <EditText
            android:layout_marginTop="9dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColorHint="@color/opacity_white"
            android:textColor="@color/white"
            android:hint="Enter password"
            android:inputType="textPassword"
            android:textColorLink="@color/primary_dark_second"
            android:backgroundTint="@color/opacity_white"
            android:paddingBottom="18dp"
            />
    </LinearLayout>
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        android:layout_marginHorizontal="21dp"
        android:backgroundTint="@color/primary_dark_second"
        >
        <TextView
            android:layout_marginVertical="14dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:fontFamily="@font/poppinsmedium"
            android:text="Log in"
            android:layout_gravity="center"
            android:textColor="@color/white"
            />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_weight="3"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        >
        <LinearLayout
            android:layout_gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            >
            <LinearLayout
                android:layout_width="37dp"
                android:layout_height="1dp"
                android:layout_gravity="bottom"
                android:background="@color/opacity_white"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="@color/opacity_white"
                android:text="or"
                android:fontFamily="@font/poppinsmedium"
                />
            <LinearLayout
                android:layout_width="37dp"
                android:layout_height="1dp"
                android:background="@color/opacity_white"
                android:layout_gravity="bottom"
                />
        </LinearLayout>
        <LinearLayout
            android:layout_marginTop="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            >
            <androidx.cardview.widget.CardView
                android:layout_width="95dp"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/white"
                app:cardCornerRadius="6dp"
                >
                <ImageView
                    android:layout_gravity="center"
                    android:layout_marginVertical="5dp"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/google_icon"/>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:layout_marginLeft="15dp"
                android:layout_width="95dp"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/white"
                app:cardCornerRadius="6dp"
                >
                <ImageView
                    android:layout_gravity="center"
                    android:layout_marginVertical="5dp"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/google_icon"/>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>